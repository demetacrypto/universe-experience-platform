{
  "name": "universe-experience-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14"
  },
  "scripts": {
    "lint": "eslint web/*.js tests/frontend/*.test.js tests/e2e/*.js playwright.config.js eslint.config.js",
    "typecheck": "npm run typecheck:strict && npm run typecheck:web",
    "typecheck:strict": "tsc --project tsconfig.json --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/frontend/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test '--test-coverage-include=web/*-utils.js' --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 tests/frontend/*.test.js",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test:coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/three": "0.160.0",
    "eslint": "^10.6.0",
    "globals": "^17.3.0",
    "three": "0.160.0",
    "typescript": "^7.0.2"
  }
}
